{
  "mcps": [
    {
      "name": "context7",
      "type": "Remote",
      "endpoint": "https://mcp.context7.com/mcp"
    },
    {
      "name": "azure",
      "type": "Local",
      "command": "dotnet",
      "arguments": ["azmcp", "server", "start"]
    },
    {
      "name": "filesystem",
      "type": "local",
      "command": "npx",
      "arguments": ["-y", "@anthropic/mcp-server-filesystem", "{{workingDirectory}}"]
    },
    {
      "name": "web-search",
      "type": "local",
      "command": "npx",
      "arguments": ["-y", "@anthropic/mcp-fetch"]
    }
  ]
}
